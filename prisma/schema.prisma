datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Dictionary model with dialect support
model Dictionary {
  id            Int      @id @default(autoincrement())
  lampungWord   String   @map("lampung_word")
  indonesiaWord String   @map("indonesia_word")
  dialect       String   @default("A") @map("dialect")
  partOfSpeech  String?  @map("part_of_speech")
  description   String?  @map("description")
  source        String?  @map("source")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([lampungWord, indonesiaWord, dialect])
  @@index([lampungWord])
  @@index([indonesiaWord])
  @@index([dialect])
  @@index([isActive])
  @@map("dictionary")
}

// Translation history model
model TranslationHistory {
  id              String   @id @default(cuid()) @map("id")
  inputText       String   @db.Text @map("input_text")
  translatedText  String   @db.Text @map("translated_text")
  direction       String   @default("lampung-to-indonesia") @db.VarChar(100) @map("direction")
  detectedDialect String?  @db.VarChar(10) @map("detected_dialect")
  nlpSteps        Json     @map("nlp_steps")
  processingTime  Int?      @map("processing_time")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("translation_history")
}

// Admin user model
model Admin {
  id        String   @id @default(cuid()) @map("id")
  username  String   @unique @db.VarChar(100) @map("username")
  email     String   @unique @db.VarChar(255) @map("email")
  password  String   @db.VarChar(255) @map("password")
  name      String?  @db.VarChar(255) @map("name")
  role      String   @default("admin") @db.VarChar(50) @map("role")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([username])
  @@map("admin")
}